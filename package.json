{
  "name": "lab3-esm",
  "version": "1.0.0",
  "description": "REST API server for Framework Technologies Lab 3",
  "main": "app.js",
  "type": "module",
  "imports": {
    "#controllers/*": "./controllers/*.js",
    "#services/*": "./services/*.js",
    "#routes/*": "./routes/*.js",
    "#data/*": "./data/*.js",
    "#constants/*": "./constants/*.js",
    "#config/*": "./config/*.js",
    "#utils/*": "./src/utils/*.js",
    "#schemas/*": "./schemas/*.js",
    "#models/*": "./src/models/*.js",
    "#repositories/*": "./src/repositories/*.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "seed": "node src/scripts/seed.js",
    "migrate": "node src/migrations/migrate.js",
    "external": "json-server db.json --port 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check"
  },
  "keywords": [],
  "author": "KYNZEK",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "json-server": "^1.0.0-beta.15",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.2.0",
    "ajv": "^8.20.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2"
  }
}
