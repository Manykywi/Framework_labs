# HTTP Server Configuration
PORT=3000
HOSTNAME=localhost

# Application Environment
# Allowed values: development|production
NODE_ENV=development

# Admin API key (for protected endpoints like GET /health/details)
ADMIN_API_KEY=change-me

# CORS (only used in production)
# Example: https://your-frontend.example
CORS_ORIGIN=https://example.com

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=lab8

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (min 32 characters)
JWT_SECRET=change-me-to-a-long-secret-value-32chars
